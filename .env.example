# ============================================================
# Leilão Inteligente - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Banco de Dados
POSTGRES_DB=leilao_inteligente
POSTGRES_USER=leilao_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Segurança JWT
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI
OPENAI_API_KEY=sk-...

# Ambiente
ENVIRONMENT=production

# Alertas - Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
EMAIL_FROM=noreply@leilaointeligente.com.br

# Alertas - WhatsApp (Twilio ou Z-API)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# Alertas - Telegram
TELEGRAM_BOT_TOKEN=

# Google Maps / OpenStreetMap
MAPS_API_KEY=

# Configurações da Aplicação
APP_NAME=Leilão Inteligente
APP_URL=https://app.leilaointeligente.com.br
ADMIN_EMAIL=admin@leilaointeligente.com.br

# Limites de Planos
PLAN_FREE_MAX_ALERTS=3
PLAN_PRO_MAX_ALERTS=50
PLAN_ENTERPRISE_MAX_ALERTS=999
